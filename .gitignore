# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
env/
venv/
.venv/
ENV/
pip-wheel-metadata/
*.pyo
*.pyd

# ── Environment files ─────────────────────────────────────────────────────────
.env
.env.*
!.env.example
!deployment/.env.production

# ── Alembic ───────────────────────────────────────────────────────────────────
# Keep the versions directory tracked, but not compiled caches
backend/alembic/__pycache__/

# ── Uploads & generated files ─────────────────────────────────────────────────
backend/uploads/documents/*
backend/uploads/processed/*
backend/uploads/failed/*
backend/uploads/temp/*
!backend/uploads/documents/.gitkeep
!backend/uploads/processed/.gitkeep
!backend/uploads/failed/.gitkeep
!backend/uploads/temp/.gitkeep

backend/static/profile_images/*
backend/static/exports/*
!backend/static/profile_images/.gitkeep
!backend/static/exports/.gitkeep

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
storage/logs/
backend/storage/logs/
*.log
*.log.*

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/
.npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── IDEs & editors ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
*.coveragerc

# ── Docker ───────────────────────────────────────────────────────────────────
# (docker-compose.yml and Dockerfiles are tracked)

# ── Secrets & keys ───────────────────────────────────────────────────────────
*.pem
*.key
*.crt
*.pfx
*.p12
secrets/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
.cache/